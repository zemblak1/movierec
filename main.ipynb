    "ratings = pd.read_csv(\n",
    "    \"ml-100k/u.data\",\n",
    "    sep=\"\\t\",\n",
    "    names=[\"user_id\", \"movie_id\", \"rating\", \"timestamp\"],\n",
    "    usecols=[\"user_id\", \"movie_id\", \"rating\"]\n",
    ")\n",
    "\n",
    "movies = pd.read_csv(\n",
    "    \"ml-100k/u.item\",\n",
    "    sep=\"|\",\n",
    "    encoding=\"latin-1\",\n",
    "    names=[\"movie_id\", \"title\"] + [f\"col_{i}\" for i in range(22)],\n",
    "    usecols=[\"movie_id\", \"title\"]\n",
    ")\n",
    "\n",
    "ratings.head()\n",
    "#movies.head()"
   ]
